// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

/**
 * Les models
 */
model User {
  id        Int       @id @default(autoincrement())
  fullname  String
  email     String    @unique
  password  String
  roleId    Int?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  role                                 Role?                      @relation(fields: [roleId], references: [id])
  commandeDetails                      CommandeDetail[]           @relation("CommandeDetailCreatedBy")
  createdCommandes                     Commande[]                 @relation("CommandeCreatedBy")
  validatedCommandes                   Commande[]                 @relation("CommandeValidatedBy")
  commandeRecusCreatedBy               CommandeRecu[]             @relation("CommandeRecuCreatedBy")
  programmationsCreatedBy              Programmation[]            @relation("ProgrammationCreatedBy")
  programmationsValidatedBy            Programmation[]            @relation("ProgrammationValidatedBy")
  ventesCreated                        Vente[]                    @relation("VenteCreatedBy")
  ventesValidated                      Vente[]                    @relation("VenteValidatedBy")
  ventesTreated                        Vente[]                    @relation("VenteTreatedBy")
  commandeClientsCreated               CommandeClient[]           @relation("CommandeClientCreatedBy")
  commandeClientsValidated             CommandeClient[]           @relation("CommandeClientValidatedBy")
  reglementsCreatedBy                  Reglement[]                @relation("ReglementCreatedBy")
  reglementsValidatedBy                Reglement[]                @relation("ReglementValidatedBy")
  approvisionnementsCreatedBy          Approvisionnement[]        @relation("ReglementCreatedBy")
  approvisionnementsValidatedBy        Approvisionnement[]        @relation("ReglementValidatedBy")
  demandeModificationVentesCreatedBy   DemandeModificationVente[] @relation("DemandeModificationVenteCreatedBy")
  demandeModificationVentesValidatedBy DemandeModificationVente[] @relation("DemandeModificationVenteValidatedBy")
  demandeSuppressionVentesCreatedBy    DemandeSuppressionVente[]  @relation("DemandeSuppressionVenteCreatedBy")
  demandeSuppressionVentesValidatedBy  DemandeSuppressionVente[]  @relation("DemandeSuppressionVenteValidatedBy")

  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String
  userId    Int
  expiresAt DateTime

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // relations
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // relations
  roles RolePermission[]

  @@map("permissions")
}

model Commande {
  id            Int       @id @default(autoincrement())
  code          String?
  date          DateTime
  montant       Float?
  validatedAt   DateTime?
  statutId      Int?
  typeId        Int?
  fournisseurId Int?
  createdById   Int?
  validatedById Int?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  statut          StatutCommande?   @relation(fields: [statutId], references: [id])
  type            TypeCommande?     @relation(fields: [typeId], references: [id])
  fournisseur     Fournisseur?      @relation(fields: [fournisseurId], references: [id])
  createdBy       User?             @relation("CommandeCreatedBy", fields: [createdById], references: [id])
  validatedBy     User?             @relation("CommandeValidatedBy", fields: [validatedById], references: [id])
  commandeDetails CommandeDetail[]
  commandeRecus   CommandeRecu[]
  commandeAccuses CommandeAccuses[]
  programmations  Programmation[]

  @@map("commandes")
}

model CommandeDetail {
  id          Int    @id @default(autoincrement())
  commandeId  Int
  productId   Int?
  qteCommande Int?
  unitePrice  Float?
  remise      Float?
  createdById Int?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  commande  Commande     @relation(fields: [commandeId], references: [id])
  product   TypeProduit? @relation(fields: [productId], references: [id])
  createdBy User?        @relation("CommandeDetailCreatedBy", fields: [createdById], references: [id])

  @@map("commande_details")
}

model CommandeRecu {
  id          Int      @id @default(autoincrement())
  commandeId  Int
  code        String?
  reference   String?
  libelle     String?
  date        DateTime
  tonnage     Float
  montant     Float
  preuve      String?
  qteRecu     Int
  createdById Int?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  commande   Commande                @relation(fields: [commandeId], references: [id])
  createdBy  User?                   @relation("CommandeRecuCreatedBy", fields: [createdById], references: [id])
  versements CommandeVersementRecu[]

  @@map("commande_recus")
}

model CommandeVersementRecu {
  id               Int      @id @default(autoincrement())
  recuId           Int?
  compteId         Int?
  typeDetailRecuId Int?
  code             String?
  reference        String?
  date             DateTime
  montant          Float
  preuve           String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  recu           CommandeRecu?           @relation(fields: [recuId], references: [id])
  compte         CompteBancaire?         @relation(fields: [compteId], references: [id])
  typeDetailRecu TypeDetailRecuCommande? @relation(fields: [typeDetailRecuId], references: [id])

  @@map("commande_versement_recu")
}

model CommandeAccuses {
  id             Int       @id @default(autoincrement())
  commandeId     Int?
  code           String?
  reference      String?
  libelle        String?
  date           DateTime
  preuve         String?
  typeDocumentId Int?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // relations
  commande     Commande?     @relation(fields: [commandeId], references: [id])
  typeDocument TypeDocument? @relation(fields: [typeDocumentId], references: [id])

  @@map("commande_accuses")
}

model Programmation {
  id            Int  @id @default(autoincrement())
  commandeId    Int?
  statutId      Int?
  zoneId        Int?
  camionId      Int?
  chauffeurId   Int?
  avaliseurId   Int?
  createdById   Int?
  validatedById Int?

  code              String    @unique
  dateProgrammation DateTime?
  dateLivraison     DateTime?
  dateSortie        DateTime?
  qteProgrammer     Float?
  qteLivre          Float?
  bl                String?
  newBl             String?
  observation       String?
  validatedAt       DateTime?
  preuve            String?
  imprimer          Boolean   @default(false)
  transfert         Boolean   @default(false)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  commande  Commande?               @relation(fields: [commandeId], references: [id])
  zone      Zone?                   @relation(fields: [zoneId], references: [id])
  statut    StatutProgrammation?    @relation(fields: [statutId], references: [id])
  camion    Camion?                 @relation(fields: [camionId], references: [id])
  chauffeur Chauffeur?              @relation(fields: [chauffeurId], references: [id])
  avaliseur AvaliseurProgrammation? @relation(fields: [avaliseurId], references: [id])

  createdBy   User? @relation("ProgrammationCreatedBy", fields: [createdById], references: [id])
  validatedBy User? @relation("ProgrammationValidatedBy", fields: [validatedById], references: [id])

  @@map("programmations")
}

model Vente {
  id Int @id @default(autoincrement())

  commandClientId Int?
  statutId        Int?
  produitId       Int?
  typeId          Int?
  clientId        Int?
  treatedById     Int?
  createdById     Int?
  validatedById   Int?

  code        String   @unique
  date        DateTime
  montant     Float?
  unitePrice  Float?
  qteTotal    Float?
  remise      Float?
  transport   Float?
  destination String?
  observation String?
  preuve      String?
  reglemented Boolean  @default(false)

  deletedAt   DateTime?
  validatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // relations
  commandeClient            CommandeClient?            @relation(fields: [commandClientId], references: [id])
  client                    Client?                    @relation(fields: [clientId], references: [id])
  createdBy                 User?                      @relation("VenteCreatedBy", fields: [createdById], references: [id])
  validatedBy               User?                      @relation("VenteValidatedBy", fields: [validatedById], references: [id])
  produit                   Produit?                   @relation(fields: [produitId], references: [id])
  statut                    StatutVente?               @relation(fields: [statutId], references: [id])
  type                      TypeCommandeClient?        @relation(fields: [typeId], references: [id])
  treatedBy                 User?                      @relation("VenteTreatedBy", fields: [treatedById], references: [id])
  reglements                Reglement[]
  venteComptabilities       VenteComptability[]
  demandeModificationVentes DemandeModificationVente[]
  demandeSuppressionVentes  DemandeSuppressionVente[]

  @@map("ventes")
}

model CommandeClient {
  id Int @id @default(autoincrement())

  statutId             Int?
  typeCommandeClientId Int?
  clientId             Int?

  code    String   @unique
  date    DateTime
  montant Float

  createdById   Int?
  validatedById Int?

  deletedAt   DateTime?
  validatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // relations
  statut      StatutCommandeClient? @relation(fields: [statutId], references: [id])
  type        TypeCommandeClient?   @relation(fields: [typeCommandeClientId], references: [id])
  client      Client?               @relation(fields: [clientId], references: [id])
  createdBy   User?                 @relation("CommandeClientCreatedBy", fields: [createdById], references: [id])
  validatedBy User?                 @relation("CommandeClientValidatedBy", fields: [validatedById], references: [id])
  ventes      Vente[]

  @@map("commande_clients")
}

model VenteComptability {
  id Int @id @default(autoincrement())

  venteId              Int?
  aib                  Float?
  tva                  Float?
  ttcPrice             Float?
  marge                Float?
  senderToComptability Int?

  treatedAt            DateTime?
  comptabilizedAt      DateTime?
  sentToComptabilityAt DateTime?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  vente Vente? @relation(fields: [venteId], references: [id])

  @@map("vente_comptabilities")
}

model Reglement {
  id Int @id @default(autoincrement())

  venteId          Int?
  clientId         Int?
  compteBancaireId Int?
  createdById      Int?
  validatedById    Int?
  typeDetailRecuId Int?

  code      String?
  reference String?

  montant           Float
  date              DateTime
  preuve            String?
  comment           String?
  validationComment String?
  deblocDette       Boolean  @default(false)

  deletedAt   DateTime?
  validatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // relations
  vente          Vente?                  @relation(fields: [venteId], references: [id])
  client         Client?                 @relation(fields: [clientId], references: [id])
  compteBancaire CompteBancaire?         @relation(fields: [compteBancaireId], references: [id])
  createdBy      User?                   @relation("ReglementCreatedBy", fields: [createdById], references: [id])
  validatedBy    User?                   @relation("ReglementValidatedBy", fields: [validatedById], references: [id])
  typeDetailRecu TypeDetailRecuCommande? @relation(fields: [typeDetailRecuId], references: [id])

  @@map("reglements")
}

model Approvisionnement {
  id Int @id @default(autoincrement())

  clientId         Int?
  compteBancaireId Int?
  createdById      Int?
  validatedById    Int?
  typeDetailRecuId Int?

  code      String?
  reference String?

  montant           Float
  date              DateTime
  preuve            String?
  comment           String?
  validationComment String?

  deletedAt   DateTime?
  validatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // relations
  client         Client?                 @relation(fields: [clientId], references: [id])
  compteBancaire CompteBancaire?         @relation(fields: [compteBancaireId], references: [id])
  createdBy      User?                   @relation("ReglementCreatedBy", fields: [createdById], references: [id])
  validatedBy    User?                   @relation("ReglementValidatedBy", fields: [validatedById], references: [id])
  typeDetailRecu TypeDetailRecuCommande? @relation(fields: [typeDetailRecuId], references: [id])

  @@map("approvisionnements")
}

model DemandeModificationVente {
  id Int @id @default(autoincrement())

  venteId       Int?
  clientId      Int?
  createdById   Int?
  validatedById Int?

  code   String?
  raison String

  date     DateTime
  preuve   String?
  modified Boolean  @default(false)

  deletedAt   DateTime?
  validatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // relations
  vente       Vente?  @relation(fields: [venteId], references: [id])
  client      Client? @relation(fields: [clientId], references: [id])
  createdBy   User?   @relation("DemandeModificationVenteCreatedBy", fields: [createdById], references: [id])
  validatedBy User?   @relation("DemandeModificationVenteValidatedBy", fields: [validatedById], references: [id])

  @@map("demande_modification_ventes")
}

model DemandeSuppressionVente {
  id Int @id @default(autoincrement())

  venteId       Int?
  clientId      Int?
  createdById   Int?
  validatedById Int?

  code   String?
  raison String

  date    DateTime
  preuve  String?
  deleted Boolean  @default(false)

  deletedAt   DateTime?
  validatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // relations
  vente       Vente?  @relation(fields: [venteId], references: [id])
  client      Client? @relation(fields: [clientId], references: [id])
  createdBy   User?   @relation("DemandeSuppressionVenteCreatedBy", fields: [createdById], references: [id])
  validatedBy User?   @relation("DemandeSuppressionVenteValidatedBy", fields: [validatedById], references: [id])

  @@map("demande_suppression_ventes")
}

/**
 * LES RELATIONS
 */

//  Table many to many entre Role et Permission
model RolePermission {
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/**
 * Les entités à migrer après
 */
model Fournisseur {
  id             Int     @id @default(autoincrement())
  sigle          String?
  raison_sociale String? @unique
  phone          String? @unique
  email          String? @unique
  adresse        String?

  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  commandes Commande[]

  @@map("fournisseurs")
}

model Camion {
  id              Int     @id @default(autoincrement())
  marqueId        Int?
  immatriculation String  @unique
  libelle         String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  marque         Marque?         @relation(fields: [marqueId], references: [id])
  programmations Programmation[]

  @@map("camions")
}

model Chauffeur {
  id       Int     @id @default(autoincrement())
  fullname String  @unique
  permis   String?
  phone    String? @unique

  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  programmations Programmation[]

  @@map("chauffeurs")
}

model AvaliseurProgrammation {
  id       Int     @id @default(autoincrement())
  fullname String  @unique
  phone    String? @unique
  email    String? @unique

  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  programmations Programmation[]

  @@map("avaliseur_programmations")
}

model Client {
  id Int @id @default(autoincrement())

  zoneId   Int?
  statutId Int?
  typeId   Int?

  nom     String
  prenom  String
  profil  String?
  phone   String? @unique
  email   String? @unique
  adresse String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  zone                      Zone?                      @relation(fields: [zoneId], references: [id])
  statut                    StatutClient?              @relation(fields: [statutId], references: [id])
  type                      TypeClient?                @relation(fields: [typeId], references: [id])
  ventes                    Vente[]
  commandeClients           CommandeClient[]
  reglements                Reglement[]
  approvisionnements        Approvisionnement[]
  demandeModificationVentes DemandeModificationVente[]
  demandeSuppressionVentes  DemandeSuppressionVente[]

  @@map("clients")
}

model Banque {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  comptes CompteBancaire[]

  @@map("banques")
}

model CompteBancaire {
  id       Int     @id @default(autoincrement())
  banqueId Int?
  numero   String  @unique
  intitule String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  banque             Banque?                 @relation(fields: [banqueId], references: [id])
  versements         CommandeVersementRecu[]
  reglements         Reglement[]
  approvisionnements Approvisionnement[]

  @@map("compte_bancaires")
}

model Produit {
  id               Int     @id @default(autoincrement())
  name             String  @unique
  description      String?
  fournisseurPrice Float?
  typeId           Int?
  image            String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // relations
  type   TypeProduit? @relation(fields: [typeId], references: [id])
  ventes Vente[]

  @@map("produits")
}

model Agent {
  id     Int     @id @default(autoincrement())
  nom    String
  prenom String
  phone  String? @unique

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("agents")
}

model Representant {
  id     Int     @id @default(autoincrement())
  nom    String
  prenom String
  phone  String? @unique
  email  String? @unique

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("representants")
}

/**
 * Les tools à inserer via seeders
 */

model Zone {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  clients        Client[]
  programmations Programmation[]

  @@map("zones")
}

model StatutCommande {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  commandes Commande[]

  @@map("statut_commandes")
}

model TypeCommande {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  commandes Commande[]

  @@map("type_commandes")
}

model TypeDocument {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  commandeAccuses CommandeAccuses[]

  @@map("type_documents")
}

model TypeDetailRecuCommande {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  CommandeVersementRecus CommandeVersementRecu[]
  reglements             Reglement[]
  approvisionnements     Approvisionnement[]

  @@map("type_detail_recu_commandes")
}

model StatutProgrammation {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  programmations Programmation[]

  @@map("statut_programmations")
}

model StatutCommandeClient {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  commandeClients CommandeClient[]

  @@map("statut_commande_clients")
}

model TypeCommandeClient {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  commandeClients CommandeClient[]
  ventes          Vente[]

  @@map("type_commande_clients")
}

model StatutVente {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  ventes    Vente[]

  @@map("statut_ventes")
}

model TypeProduit {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  commandeDetails CommandeDetail[]
  produits        Produit[]

  @@map("type_produits")
}

model StatutClient {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  clients   Client[]

  @@map("statut_clients")
}

model TypeClient {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  clients   Client[]

  @@map("type_clients")
}

model Marque {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  camions   Camion[]

  @@map("marques")
}
